# Auto detect text files and perform LF normalization
* text=auto
# Web UI assets frozen into the EXE must be byte-identical regardless of the
# checkout platform (Windows CI checks out CRLF, local dev tree is LF). Pin
# them to -text so the frozen bundle matches across builds.
src/wordle_solver/desktop/web/index.html -text
src/wordle_solver/desktop/web/styles.css -text
src/wordle_solver/desktop/web/*.html -text
src/wordle_solver/desktop/web/*.css -text
