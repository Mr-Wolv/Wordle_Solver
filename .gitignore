.ruff_cache/

# PyPI configuration file
.pypirc

# Cursor  
#  Cursor is an AI-powered code editor.`.cursorignore` specifies files/directories to 
#  exclude from AI features like autocomplete and code analysis. Recommended for sensitive data
#  refer to https://docs.cursor.com/context/ignore-files
.cursorignore
.cursorindexingignore

/wordle_full_matrix.npy              # GENERATED by build_matrix.py at build time
/scientific_word_data.csv           # source data; force-committed (build_matrix.py reads it)
/residual_optimal_nohint.json       # committed baseline (hard no-hint closure tree)
/turn1_cache.json                   # GENERATED by the engine at build time (preload step)
/residual_optimal.json              # committed baseline (hard+hint residual tree; multi-hour prover)
/t1_h_opening.json                  # committed baseline (turn-1 heuristic openings)
/turn1_cache.*.json                 # stray per-port dev caches (NEVER committed)
find_t1_h.log
# Force-add the committed data artifacts so the build/exe is reproducible from a
# clean checkout (these are inputs the spec/bundle requires and CI does not regenerate).
!scientific_word_data.csv
!residual_optimal.json
!residual_optimal_nohint.json
!t1_h_opening.json